# ─────────────────────────────────────────────────────────
# Skill Navigator Backend — Environment Variables
# ─────────────────────────────────────────────────────────
# ⚠️  DO NOT COMMIT THIS FILE — it's in .gitignore
#
# How to find these values:
#   → supabase.com → your project → Settings → Database
#   → Connection string: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
# ─────────────────────────────────────────────────────────

# Supabase PostgreSQL connection
# Format: jdbc:postgresql://HOST:PORT/DATABASE?sslmode=require
SUPABASE_DB_URL=jdbc:postgresql://db.pgnvqldaunqausapobjx.supabase.co:5432/postgres?sslmode=require

# Database credentials (Settings → Database → Connection Info)
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD_HERE

# JWT Secret for verifying Supabase user tokens
# Found at: supabase.com → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET_HERE
